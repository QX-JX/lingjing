{
  "name": "zhihui-voice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "智绘配音 - 文本转语音应用",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:1420 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "tauri": "tauri"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@tiptap/extension-character-count": "^3.15.3",
    "@tiptap/extension-dropcursor": "^3.15.3",
    "@tiptap/extension-focus": "^3.15.3",
    "@tiptap/extension-gapcursor": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.562.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tippy.js": "^6.3.7",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.zhihui.voice",
    "productName": "智绘配音",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "../icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon.icns"
    }
  }
}
